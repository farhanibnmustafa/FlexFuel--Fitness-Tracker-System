PORT=3001
SESSION_SECRET=change-me

# Supabase configuration
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# App base URL (used in email links)
APP_URL=

# Email (SMTP) configuration
# Option A: single connection string
SMTP_URL=
# Option B: host/port credentials
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Weekly report job
WEEKLY_REPORT_SWEEP_HOURS=12
DISABLE_WEEKLY_REPORT_JOBS=false

# Forgot password OTP
PASSWORD_RESET_OTP_EXPIRY_MINUTES=10
PASSWORD_RESET_OTP_COOLDOWN_SECONDS=45
PASSWORD_RESET_OTP_MAX_ATTEMPTS=5

# API performance
MEAL_PLAN_CACHE_TTL_MS=120000
